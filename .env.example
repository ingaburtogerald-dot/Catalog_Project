# ===== Servidor =====
PORT=3000
ONEDRIVE_SHARING_URL=

# ===== Negocio =====
WHATSAPP_NUMBER=50585944758
CURRENCY=C$
VOLUME_MIN_QTY=3
VOLUME_PERCENT=10

# ===== Firebase Admin SDK (servidor) =====
# Console Firebase → ⚙️ Configuración del proyecto → Cuentas de servicio → Generar nueva clave privada.
SERVICE_ACCOUNT_PATH=./server/serviceAccountKey.json

# ===== Autenticación del admin con Google (Firebase Authentication) =====
# Correos de Google autorizados como administradores (separados por coma).
ADMIN_EMAILS=ingaburtogerald@gmail.com

# Config pública de la Web App de Firebase.
# Console → ⚙️ Configuración del proyecto → Tus apps → (Web) → Configuración del SDK.
# Estos valores NO son secretos: son seguros para incluir en el navegador.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
